structure fib
(
    rec = λ a b i → out
    (
        int   dup  b     → b₁ a'
        int   add  b₁ a  → b'

        int   cons_1     → one
        int   sub  i one → i'

        fib   loop               → cont
        fᵢᵢᵢⁱ call cont a' b' i' → out
    )

    base = λ a b i → out
    (
        int drop a
        int drop i
        int move b → out
    )

    frame = λ A B a b i → out
    (
        int dup a → a₁ a₂
        int dup b → b₁ b₂
        int dup i → i₁ i₂

        fᵢᵢᵢⁱ call A a₁ b₁ i₁ → out₁
        fᵢᵢᵢⁱ call B a₂ b₂ i₂ → out₂
        int join out₁ out₂ → out
    )

    loop = λ a b i → out
    (
        int cons_0      → zero
        int dup i       → i₁ i₂
        int le? i₁ zero → cmp

        bool dup cmp   → cmp₁ cmp₂
        bool not cmp₂  → cmp₃

        fib base  → base
        fib rec   → rec
        fib frame → frame

        fᵢᵢᵢⁱ opt cmp₁ base → alt₁
        fᵢᵢᵢⁱ opt cmp₃ rec  → alt₂

        fᵢᵢᵢⁱ join alt₁ alt₂ frame → cont
        fᵢᵢᵢⁱ call cont a b i₂     → out
    )

    compute = λ in → out
    (
        int  cons_1    → a ; construct 1 on stack $a
        int  cons_1    → b ; construct 1 on stack $b
        int  cons_2    → x ; construct 2 on stack $x

        int  sub  in x → i

        fib   loop            → cont
        fᵢᵢᵢⁱ call cont a b i → out
    )
)

structure main
(
    run = λ
    (
        int cons_5 → a

        fib compute        → program
        fᵢⁱ call program a → out

        int cons_5  → b
        int eq?  out b → c

        bool assert c
    )
)

