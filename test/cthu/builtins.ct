; everything as a jsvalue ? 

structure int : arithmetic[ int, stck, bool ]
(
    dup  = qjs_int_dup
    drop = qjs_int_drop
    move = qjs_int_move
    join = qjs_int_join
    
    push = qjs_int_push
    pop  = qjs_int_pop

    add = qjs_int_add 
    sub = qjs_int_sub 
    mul = qjs_int_mul 
    div = qjs_int_div 
    rem = qjs_int_rem 

    eq? = qjs_int_eq 
    ne? = qjs_int_ne 
    lt? = qjs_int_lt 
    le? = qjs_int_le 
    ge? = qjs_int_ge 
    gt? = qjs_int_gt 

    shl = qjs_int_ashl 
    shr = qjs_int_ashr 

    cons_0 = qjs_int_cons_0

    cons_1 = qjs_int_cons_1
    cons_2 = qjs_int_cons_2
    cons_3 = qjs_int_cons_3
    cons_4 = qjs_int_cons_4
)

structure bool : logical[ bool ]
(
    dup    = qjs_bool_dup
    not    = qjs_bool_not
    and    = qjs_bool_and
    or     = qjs_bool_or
    xor    = qjs_bool_xor
    assert = qjs_bool_assert
)

structure fᵢⁱ : f₁¹[ func, i₃₂, bool, i₃₂, i₃₂ ]
(
    call = qjs_func_call
    join = qjs_func_join
    opt  = qjs_func_opt
)

structure fᵢᵢᵢⁱ : f₃¹[ func, i₃₂, i₃₂, i₃₂, i₃₂ ]
(
    call = qjs_func_call
    join = qjs_func_join
    opt  = qjs_func_opt
)
