; The ‹w₃₂› structure provides an implementation of ‹simple› for the built-in
; 32-bit word type.

structure w₃₂ : simple[ w₃₂, stck ]
(
    dup  = builtin_bv32dup
    drop = builtin_bv32drop
    move = builtin_bv32move
    fork = builtin_bv32fork

    push = builtin_bv32push
    pop  = builtin_bv32pop
)

structure bool : logical[ bool ]
(
    dup = builtin_bool_dup
    not = builtin_bool_not
    and = builtin_bool_and
    or  = builtin_bool_or
    xor = builtin_bool_xor
    assert = builtin_bool_assert
)

structure fᵢⁱ : f₁¹[ func, i₃₂, bool, i₃₂, i₃₂ ]
(
    call = builtin_func_call
    join = builtin_func_join
    opt  = builtin_func_opt
)

structure fᵢᵢᵢⁱ : f₃¹[ func, i₃₂, i₃₂, i₃₂, i₃₂ ]
(
    call = builtin_func_call
    join = builtin_func_join
    opt  = builtin_func_opt
)

structure i₃₂ : arithmetic[ w₃₂, stck, bool ]
(
    dup  = builtin_bv32dup
    fork = builtin_bv32dup
    drop = builtin_bv32drop
    move = builtin_bv32move
    join = builtin_bv32join

    add = builtin_bv32add
    sub = builtin_bv32sub
    mul = builtin_bv32mul
    div = builtin_bv32sdiv
    rem = builtin_bv32srem

    eq? = builtin_bv32eq
    ne? = builtin_bv32ne
    lt? = builtin_bv32slt
    le? = builtin_bv32sle
    ge? = builtin_bv32sge
    gt? = builtin_bv32sgt

    shl = builtin_bv32shl
    shr = builtin_bv32ashr

    cons_0   = builtin_bv32cons_0
    cons_1   = builtin_bv32cons_1
    cons_2   = builtin_bv32cons_2
    cons_16  = builtin_bv32cons_16
    cons_987 = builtin_bv32cons_987
)

structure u₃₂ : arithmetic[ w₃₂, stck, bool ]
(
    dup  = builtin_bv32dup
    fork = builtin_bv32dup
    drop = builtin_bv32drop
    move = builtin_bv32move
    join = builtin_bv32join

    add = builtin_bv32add
    sub = builtin_bv32sub
    mul = builtin_bv32mul
    div = builtin_bv32udiv
    rem = builtin_bv32urem

    eq? = builtin_bv32eq
    ne? = builtin_bv32ne
    lt? = builtin_bv32ult
    le? = builtin_bv32ule
    ge? = builtin_bv32uge
    gt? = builtin_bv32ugt

    shl = builtin_bv32shl
    shr = builtin_bv32lshr
)

structure u₁₆³² : convert[ w₁₆, w₃₂ ]
(
    cut = builtin_bv32trunc16
    ext = builtin_bv16zext32
)

structure i₁₆³² : convert[ w₁₆, w₃₂ ]
(
    cut = builtin_bv32trunc16
    ext = builtin_bv16sext32
)
