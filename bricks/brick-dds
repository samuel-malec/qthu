    struct lcg_param
    {
        TEST( inverse )
        {
            for ( auto [ p, a, a_inv ] : brq::lcg_param )
                ASSERT_EQ( brq::mul64_mod( a, a_inv, p ), 1, a, a_inv );
        }
    };

    struct ddsplit
    {
        TEST( stream )
        {
            std::vector< std::string > data = { "hel", "lo ", "worl", "d", "" };
            int i = 0;
            brq::ddstream s( [&]{ return data[ i++ ]; } );

            for ( char c : std::string_view( "hello world" ) )
            {
                ASSERT( !s.empty() );
                ASSERT_EQ( s.fetch_char(), c );
            }

            ASSERT( s.empty() );
        }

        TEST( chunk )
        {
            std::mt19937 rand;
            std::uniform_int_distribution<> dist( 0, 255 );

            std::vector< std::string > data;
            std::string rebuilt, expected;

            for ( int i = 0; i < 16000; ++i )
            {
                data.emplace_back();
                for ( int j = 0; j < 1000; ++j )
                    data.back() += dist( rand );
                expected += data.back();
            }

            data.emplace_back();

            for ( int mean : { 8000, 16000, 32000, 64000, 128000 } )
            {
                std::vector< int > sizes;
                int i = 0;
                brq::ddsplit s( mean, 3 * mean, [&]{ return data[ i++ ]; } );

                for ( auto c : s )
                {
                    // rebuilt += c;
                    sizes.push_back( c.size() );
                }

                // ASSERT_EQ( rebuilt, expected );

                std::cerr << std::endl;
                std::cerr << "[ " << *std::min_element( sizes.begin(), sizes.end() ) << " "
                                  << expected.size() / sizes.size() << " "
                                  << *std::max_element( sizes.begin(), sizes.end() ) << " ] "
                          << sizes.size() << "; "
                          << s.modulus() << " " << s.base() << " " << s.h_seen.size() << std::endl;

                std::sort( sizes.begin(), sizes.end() );
                for ( auto s : sizes )
                    std::cerr << s << " ";
                std::cerr << std::endl;
            }
        }
    };
