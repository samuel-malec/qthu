    struct ddstream
    {
        std::string buf;
        int buf_idx = 0;
        int64_t idx = 0;

        using fetch_t = std::function< std::string() >;
        fetch_t fetch;

        ddstream( fetch_t fetch ) : fetch( fetch )
        {
            buf = std::move( fetch() );
        }

        ddstream( std::string s ) : buf( std::move( s ) ) {}

        void fetch_if_needed()
        {
            if ( buf_idx == buf.size() && !buf.empty() )
                buf = fetch ? fetch() : "", buf_idx = 0;
        }

        char fetch_char()
        {
            fetch_if_needed();
            ++ idx;
            return buf[ buf_idx ++ ];
        }

        bool empty()
        {
            fetch_if_needed();
            return buf.empty();
        }
    };

    struct ddhash
    {
        const int min_size, mean_size, max_size;
        using param_t = std::tuple< uint64_t, uint64_t, uint64_t >;
        const param_t param;

        uint64_t modulus()  const { return std::get< 0 >( param ); }
        uint64_t base()     const { return std::get< 1 >( param ); }
        uint64_t base_inv() const { return std::get< 2 >( param ); }

        const int win_min = 4, win_max;
        uint64_t hash = 0;
        uint64_t power;

        ddhash( int mean, param_t p )
            : min_size( mean / 5 ), mean_size( mean ), max_size( 3 * mean ),
              param( p ), win_max( std::max( 2 * win_min, mean / 2 ) ), power( base() )
        {}

        ddhash( int mean, int needbits ) : ddhash( mean, lcg_param[ needbits ] ) {}
        ddhash( int mean ) : ddhash( mean, std::round( 2 * std::log2( mean ) ) ) {}

        void update( unsigned char ch )
        {
            hash += ch * power;
            hash %= modulus(); // ( uint64_t( hash ) * base() + ch ) % modulus();
            power = ( power * base() ) % modulus();
        }
    };

    struct ddsplit : ddstream, ddhash
    {
        std::unordered_map< uint64_t, int > h_seen;
        std::deque< uint64_t > h_win;
        std::string chunk;
        std::unique_ptr< ddsplit > recurse;
        int recurse_depth = 0;

        ddsplit( int mean, std::string buf ) : ddstream( buf ), ddhash( mean ) {}
        ddsplit( int mean, fetch_t fetch ) : ddstream( fetch ), ddhash( mean ) {}
        ddsplit( int mean, param_t p, fetch_t fetch ) : ddstream( fetch ), ddhash( mean, p ) {}
        ddsplit( int mean, param_t p, std::string buf ) : ddstream( buf ), ddhash( mean, p ) {}

        std::string &chunk_get()
        {
            if ( recurse )
                return recurse->chunk_get();
            else
            {
                TRACE( "yielding at", idx, "size", chunk.size(), "max", max_size );
                return chunk;
            }
        }

        bool in_window( int where ) const
        {
            return where >= idx - win_max &&
                   where <= idx - win_min;
        }

        bool empty()
        {
            if ( recurse && !recurse->empty() )
                return false;
            return ddstream::empty();
        }

        bool chunk_extend()
        {
            if ( empty() )
                return maybe_recurse(), false; /* no more data */

            bool end = false;
            char ch = fetch_char();
            chunk += ch;
            update( ch );

            h_win.push_back( hash );

            if ( auto it = h_seen.find( hash ); it != h_seen.end() )
            {
                end = in_window( it->second ) && chunk.size() > min_size;
                ASSERT_LEQ( idx - win_max, it->second );
                it->second = idx;
            }
            else
                h_seen.emplace( hash, idx );

            if ( h_win.size() > win_max )
            {
                auto drop = h_win.front();
                auto it = h_seen.find( drop );
                ASSERT( it != h_seen.end() );

                if ( it->second <= idx - win_max )
                    h_seen.erase( it );
                h_win.pop_front();
            }

            ASSERT( h_win.size() <= win_max );

            if ( end )
                maybe_recurse();

            return !end;
        }

        void maybe_recurse()
        {
            if ( chunk.size() >= max_size && recurse_depth < 3 )
            {
                TRACE( "recurse at", idx, "size", chunk.size(), "max", max_size );

                param_t p_rec{ modulus(),
                               ( base() * base() ) % modulus(),
                               ( base_inv() * base_inv() ) % modulus() };

                recurse.reset( new ddsplit( mean_size, p_rec, std::move( chunk ) ) );
                recurse->recurse_depth = recurse_depth + 1;
                recurse->chunk_next();
                chunk.clear();
            }
        }

        void chunk_next()
        {
            chunk.clear();

            if ( recurse && recurse->empty() )
                recurse.reset();

            if ( recurse )
                recurse->chunk_next();
            else
                while ( chunk_extend() );
        }

        struct iterator
        {
            ddsplit &s;
            bool _end;

            iterator &operator++()
            {
                if ( s.empty() )
                    _end = true;
                else
                    s.chunk_next();

                return *this;
            }
            bool operator!=( const iterator &o ) { return _end != o._end; }
            std::string &operator*() { return s.chunk_get(); }
        };

        iterator begin() { chunk_next(); return { *this, false }; }
        iterator end()   { return { *this, true }; }
    };

